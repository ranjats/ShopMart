rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - order_id: string (required) - Unique order identifier
    //   - customer_phone: string (required) - Customer WhatsApp JID
    //   - customer_name: string (required) - Customer push name
    //   - items: string (required) - List of items ordered
    //   - status: string (required, in ['pending', 'preparing', 'ready', 'completed'])
    //   - bill_amount: number (required) - Total bill amount
    //   - created_at: string (required) - ISO date string
    //   - updated_at: string (required) - ISO date string
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name: string (required) - Product name
    //   - price: number (required) - Product price
    //   - in_stock: number (required, in [0, 1]) - 1 if in stock, 0 if out of stock
    //   - quantity: number (required) - Available quantity
    //   - created_at: string (required) - ISO date string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAnonymous() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isAdmin() {
      // For this app, we assume any authenticated user who is NOT anonymous is an admin (logged in via Google)
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidOrder(data) {
      return hasOnlyAllowedFields(['order_id', 'customer_phone', 'customer_name', 'items', 'status', 'bill_amount', 'created_at', 'updated_at', 'shop_id']) &&
             data.order_id is string && data.order_id.size() > 0 && data.order_id.size() < 50 &&
             data.customer_phone is string && data.customer_phone.size() > 0 && data.customer_phone.size() < 50 &&
             data.customer_name is string && data.customer_name.size() > 0 && data.customer_name.size() < 100 &&
             data.items is string && data.items.size() > 0 && data.items.size() < 2000 &&
             data.status in ['pending', 'preparing', 'ready', 'completed'] &&
             data.bill_amount is number && data.bill_amount >= 0 &&
             data.created_at is string && data.created_at.size() < 50 &&
             data.updated_at is string && data.updated_at.size() < 50 &&
             data.shop_id is string && data.shop_id.size() > 0;
    }

    function isValidProduct(data) {
      return hasOnlyAllowedFields(['name', 'price', 'in_stock', 'quantity', 'created_at', 'shop_id']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.in_stock is number && (data.in_stock == 0 || data.in_stock == 1) &&
             data.quantity is number && data.quantity >= 0 &&
             data.created_at is string && data.created_at.size() < 50 &&
             data.shop_id is string && data.shop_id.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /shops/{shopId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /orders/{orderId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    match /products/{productId} {
      allow read, update: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProduct(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /whatsapp_sessions/{shopId} {
      allow read, write: if isAuthenticated();
      match /data/{docId} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
